nceTd">
<p local-id=3D"07528f1d6b44">Text (GUID)</p></td>
<td data-local-id=3D"3b74743a-7fed-4d5d-9135-1bbde2d2fb40" class=3D"conflue=
nceTd">
<p local-id=3D"8f494a4aea46">The unique identifier of the business segment =
associated with the reservation. May be empty if no segment is assigned.</p=
></td>
</tr>
<tr data-local-id=3D"36905d5c-29c1-4153-9f9a-9adc8bcad510">
<td data-local-id=3D"c6be3ea9-3e82-474c-9e6f-c15a337763e8" class=3D"conflue=
nceTd">
<p local-id=3D"5117e19187d4"><strong>Booker ID</strong></p></td>
<td data-local-id=3D"d127bdd1-1c5b-4c64-a5d0-1fea1c293fac" class=3D"conflue=
