<td data-local-id=3D"2af45753-cbfa-4eaa-81c8-10c92fce6e19" class=3D"conflue=
nceTd">
<p local-id=3D"8a2e41a3d337">The total number of reservations that failed t=
o upgrade.</p></td>
</tr>
<tr data-local-id=3D"b82b99a3-a39d-4430-ba51-e0a428ce01d5">
<td data-local-id=3D"2dcea906-6524-469d-abd5-b2e3823d646b" class=3D"conflue=
nceTd">
<p local-id=3D"0e57c3f0253f"><strong>Failed Reservation IDs</strong></p></t=
d>
