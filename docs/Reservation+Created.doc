nceTd">
<p local-id=3D"9b212a71c2b0">Text</p></td>
<td data-local-id=3D"92e4cb5c-c400-4045-b994-09a952848f8a" class=3D"conflue=
nceTd">
<p local-id=3D"4fbae104c326">The ISO 3166-1 alpha-2 country code representi=
ng the guest's nationality (e.g., <code>US</code>, <code>GB</code>, <code>D=
E</code>). May be empty if not provided.</p></td>
</tr>
<tr data-local-id=3D"d9853b9d-a681-4ff2-8683-38349cf3382c">
<td data-local-id=3D"8930e2b1-03cc-4466-9f9e-f9b0e35a5661" class=3D"conflue=
nceTd">
<p local-id=3D"c4282e3ffdfe"><strong>Guest Preferred Language Code</strong>=
</p></td>
<td data-local-id=3D"af29b385-5976-4cd2-ab09-250038ad16b5" class=3D"conflue=
nceTd">
<p local-id=3D"4db927040153">Text</p></td>
<td data-local-id=3D"fac38a20-675a-4d66-be9f-60edaa7559a5" class=3D"conflue=
nceTd">
<p local-id=3D"92634c48306e">The language code representing the guest's pre=
ferred language (e.g., <code>en-US</code>, <code>de-DE</code>). May be empt=
y if not set.</p></td>
</tr>
<tr data-local-id=3D"81e069f5-483a-4374-a456-82b842da30e3">
<td data-local-id=3D"9bc57657-55b7-4b7b-b079-e30b01ffc1d8" class=3D"conflue=
nceTd">
<p local-id=3D"b83def4e26d0"><strong>Guest Loyalty Code</strong></p></td>
<td data-local-id=3D"8a9a1cbc-145c-4ce8-9bb8-d30d60bc90b6" class=3D"conflue=
nceTd">
<p local-id=3D"8d0021f6a933">Text</p></td>
<td data-local-id=3D"8b53ff5e-e4d3-4674-9add-c45550978157" class=3D"conflue=
nceTd">
<p local-id=3D"181bb681a888">The loyalty program membership code of the gue=
st. May be empty if the guest is not enrolled in a loyalty program.</p></td=
>
</tr>
<tr data-local-id=3D"c77f6e6f-39d5-4d57-859f-ac9c49922af2">
<td data-local-id=3D"1fd0a102-2ab3-43ae-b90d-3cf554df9fee" class=3D"conflue=
nceTd">
<p local-id=3D"4b07916098bb"><strong>Guest External Identifier</strong></p>=
</td>
<td data-local-id=3D"83aa59f7-849b-4161-a988-1feea1d93374" class=3D"conflue=
nceTd">
<p local-id=3D"5ae88043ff0b">Text</p></td>
<td data-local-id=3D"49f0c8d2-1085-4815-bb98-a10a2de2d74d" class=3D"conflue=
nceTd">
<p local-id=3D"3c43e709a4cd">An external identifier for the guest, typicall=
y used for integration with third-party systems (e.g., a CRM or PMS). May b=
e empty if not set.</p></td>
</tr>
</tbody>
</table>
</div>
