nceTd">
<p local-id=3D"88f3e1fbee71">Date &amp; Time</p></td>
<td data-local-id=3D"6ad8bf96-7985-45c3-8322-e99c7509ad5a" class=3D"conflue=
nceTd">
<p local-id=3D"a0bc197f9885">The expected departure date and time in UTC (I=
SO 8601 format).</p></td>
</tr>
<tr data-local-id=3D"cc17ce54-26bf-445e-a783-9467fd40032b">
<td data-local-id=3D"2a091968-b04c-4e86-a9eb-07b8602bb90e" class=3D"conflue=
