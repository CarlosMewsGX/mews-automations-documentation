nceTd">
<p local-id=3D"7434064f7505">Text (GUID)</p></td>
<td data-local-id=3D"cdc18dad-da62-445d-b6e4-1365ca3fe4bd" class=3D"conflue=
nceTd">
<p local-id=3D"6074f3457544">The unique identifier of the guest associated =
with the reservation.</p></td>
</tr>
<tr data-local-id=3D"27ffc236-bba9-4be5-bd97-6c7e1ba5b729">
<td data-local-id=3D"499f54cb-c3e5-4ffa-9d8c-6748464ee027" class=3D"conflue=
nceTd">
<p local-id=3D"b0edd171debd"><strong>Guest First Name</strong></p></td>
<td data-local-id=3D"65b4f50a-e4a1-465d-b391-3ea9b0731c07" class=3D"conflue=
nceTd">
<p local-id=3D"ff4933217df8">Text</p></td>
<td data-local-id=3D"e522ce70-0328-4e08-86e6-a25c81139b3d" class=3D"conflue=
nceTd">
<p local-id=3D"ccb3647742db">The first name of the guest.</p></td>
</tr>
<tr data-local-id=3D"278ef726-5d54-4e16-89e6-cef948d3b281">
<td data-local-id=3D"0ed54a93-5f78-40ca-9437-701c4c21c429" class=3D"conflue=
nceTd">
<p local-id=3D"822e3f8860d2"><strong>Guest Last Name</strong></p></td>
<td data-local-id=3D"f4a66da0-8d30-44b6-af67-7003054123ed" class=3D"conflue=
