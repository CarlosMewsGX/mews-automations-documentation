<td data-local-id=3D"a522e60e-634c-40db-a470-3850894f4944" class=3D"conflue=
nceTd">
<p local-id=3D"c08fdcdb2130">Additional details about the reservation origi=
n, such as the name of the specific channel or booking source. May be empty=
 if no additional details are available.</p></td>
</tr>
<tr data-local-id=3D"82c1b025-ea77-4bcc-b7fe-d17a88ddcefc">
