nceTd">
<p local-id=3D"86a9d0ba15ce">Text (GUID)</p></td>
<td data-local-id=3D"92fbf249-edac-4f9e-896e-048dafc9c276" class=3D"conflue=
nceTd">
<p local-id=3D"13d57eba7162">The unique identifier of the bookable service =
(e.g., accommodation) that the reservation belongs to.</p></td>
</tr>
<tr data-local-id=3D"cdba66c2-1da5-4937-9a33-7852bbc0ea42">
<td data-local-id=3D"6553248e-fd80-4e79-9e37-916a080871bb" class=3D"conflue=
nceTd">
