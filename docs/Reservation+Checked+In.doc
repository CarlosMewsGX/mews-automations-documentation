<td data-local-id=3D"51ea74fa-6089-4928-a11f-1318a21823c1" class=3D"conflue=
nceTd">
<p local-id=3D"4dfaf780bcd3">Text (GUID)</p></td>
<td data-local-id=3D"b6b2408b-a4a4-4d3d-9d7f-b249c1fa328d" class=3D"conflue=
nceTd">
<p local-id=3D"864bc76fe3be">The unique identifier of the rate applied to t=
he reservation. May be empty if no rate is assigned.</p></td>
</tr>
<tr data-local-id=3D"6351ef3c-9ef4-4184-bafc-d6bf9671b5e2">
<td data-local-id=3D"042eeaf3-d58e-44ca-a1ae-6dc829093103" class=3D"conflue=
nceTd">
